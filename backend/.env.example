POSTGRES_DB=assistant_db
POSTGRES_USER=assistant_user
POSTGRES_PASSWORD=assistant_pass
DATABASE_URL=postgresql+psycopg://assistant_user:assistant_pass@db:5432/assistant_db

JWT_SECRET=very_insecure_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_MINUTES=10080

HF_TOKEN=your_huggingface_token
HF_MODEL=google/gemma-2-9b-it
# If the router returns model_not_supported, set a provider you enabled (e.g. featherless-ai).
HF_INFERENCE_PROVIDER=featherless-ai
# Set to 1 and pip install -r requirements-llm.txt for local Gemma 4 (needs transformers>=4.57.6).
HF_LOCAL_TRANSFORMERS=0

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/integrations/notion/oauth/callback
NOTION_OAUTH_STATE_TTL_MINUTES=10

RUN_TESTS_ON_STARTUP=1
